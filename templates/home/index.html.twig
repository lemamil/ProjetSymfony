{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
 <h1>Accueil</h1>
<p>Bienvenue sur mon site</p>
<form>
  <div class="form-group">
    <label for="exampleFormControlInput1">Email</label>
    <input type="email" class="form-control" id="exampleFormControlInput1" placeholder="name@example.com">
  </div>
  <div class="form-group">
    <label for="exampleFormControlTextarea1">Description</label>
    <textarea class="form-control" id="exampleFormControlTextarea1" rows="3"></textarea>
  </div>
  <div class="form-group">
    <label for="exampleFormControlSelect1">Catégorie</label>
    <select class="form-control" id="exampleFormControlSelect1">
      <option>Incident</option>
      <option>Panne</option>
      <option>Evolution</option>
      <option>Anomalie</option>
      <option>Information</option>
    </select>
  </div>
  <div class="form-group">
    <label for="exampleFormControlInput1">Date d'ouverture</label>
    <input type="date" class="form-control" id="exampleFormControlInput1">
  </div>
  <div class="form-group">
    <label for="exampleFormControlInput1">Date de clôture</label>
    <input type="date" class="form-control" id="exampleFormControlInput1">
  </div>
  <div class="form-group">
    <label for="exampleFormControlSelect1">Statut</label>
    <select class="form-control" id="exampleFormControlSelect1">
      <option>Nouveau</option>
      <option>Ouvert</option>
      <option>Résolu</option>
      <option>Fermé</option>
    </select>
  </div>
</form>

<button type="submit">Valider</button>
{% endblock %}
